rules_version = '2';

// ==========================================================================
// RCLL Scheduler — Firestore security rules
//
// Data is tenant-scoped under /organizations/{orgId}/<collection>/{id}. The
// store's in-memory collections map to Firestore collections as follows:
//   users        -> users                employees  -> employeeProfiles
//   availability -> availabilityPatterns workingHours -> workingHoursPatterns
//   leave       -> leaveRecords
//   notes        -> managerNotes         dailyNotes  -> dailyNotes
//   coverage     -> coverageRequirements swaps       -> swapRequests
//   overrides    -> complianceOverrides  audit       -> auditEvents
//   (others keep their name: schedules, shifts, positions, tasks, leaveTypes,
//    locations, operatingHours, departments, teams, breakPolicies, notifications)
//
// Model notes:
//   * The platform tracks only availability exceptions (leaveRecords) — no
//     paid-leave categories and no approval queue. Employees record their own
//     exceptions; admins/managers may record or update them on an employee's
//     behalf. Reasons stay confidential to admin/manager/owner.
//   * dailyNotes are dashboard announcements. Anyone signed in may read a
//     PUBLISHED note; managers author their own drafts; only admins may
//     publish/unpublish. Historical operational records are never deletable.
// ==========================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    // ---- Identity / role helpers (coarse checks via custom claims) ----
    function signedIn() { return request.auth != null; }
    function hasRole(role) { return signedIn() && request.auth.token.roles != null && role in request.auth.token.roles; }
    // A person's ONE canonical account id, derived from their verified Google
    // email so both Stanford logins (@law.stanford.edu and @stanford.edu) resolve
    // to the same account: any *.stanford.edu sub-domain folds to stanford.edu.
    // MUST stay in sync with canonicalizeStanfordEmail()/accountIdForEmail() in
    // src/lib/config.ts + src/lib/authz.ts.
    function canonicalEmail() {
      let e = request.auth.token.email.lower();
      let local = e.split('@')[0];
      let domain = e.split('@')[1];
      return (domain == 'stanford.edu' || domain.matches('.*[.]stanford[.]edu'))
        ? local + '@stanford.edu'
        : e;
    }
    // The canonical account id for the signed-in user (empty if no verified email).
    function emailAccountId() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        ? canonicalEmail() : '';
    }
    // The person owns this record when its employeeId is their canonical account
    // id — or their raw Firebase UID, which covers data written before the
    // account-unification migration re-keyed it.
    function owns(employeeId) {
      return signedIn() && (employeeId == emailAccountId() || employeeId == request.auth.uid);
    }
    // Break-glass: the bootstrap administrators are trusted by verified email, so
    // they are always admins even before their custom claims are set (e.g. before
    // `npm run seed` runs, or if it targeted the wrong project). This lets them
    // self-provision/repair their own user document and never lock themselves out.
    // Compared canonically so either Stanford login is recognized.
    // KEEP IN SYNC with BOOTSTRAP_ADMINS in src/lib/config.ts.
    function bootstrapAdminEmails() {
      return [
        'whuggins@stanford.edu',
        'cadena@stanford.edu',
        'blalfaro@stanford.edu',
        'gwilson@stanford.edu',
        'bwilli@stanford.edu'
      ];
    }
    function isBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && canonicalEmail() in bootstrapAdminEmails();
    }
    function isAdmin() { return hasRole('SUPER_ADMIN') || isBootstrapAdmin(); }
    function isManager() { return hasRole('MANAGER') || hasRole('SCHEDULER'); }
    function isStaff() { return isAdmin() || isManager(); }
    // The account doc / profile / record belongs to the signed-in person when its
    // key is their canonical account id (or legacy UID, pre-migration).
    function isSelf(userId) { return signedIn() && (userId == emailAccountId() || userId == request.auth.uid); }
    // The field named `field` is unchanged between the current and incoming doc.
    function unchanged(field) { return request.resource.data[field] == resource.data[field]; }

    // ---- Accounts & profiles ----
    match /organizations/{orgId}/users/{userId} {
      allow read: if isStaff() || isSelf(userId);
      // Self-registration: on first Google sign-in a person may create ONLY the
      // account for their own canonical email, as pending with no roles — so
      // administrators can see them and grant access. They may list only their own
      // uid/email on it. Everything else (approval, roles, suspension) is admin-only.
      allow create: if isAdmin()
        || (isSelf(userId)
            && request.resource.data.state == 'pending_approval'
            && request.resource.data.roles.size() == 0
            && request.resource.data.uids.hasOnly([request.auth.uid])
            && request.resource.data.signInEmails.hasOnly([request.auth.token.email.lower()]));
      // Admins manage approval/roles/state. A person may otherwise only LINK the
      // device they are on to their own account — adding their uid/email — and can
      // never touch roles or state.
      allow update: if isAdmin()
        || (isSelf(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['uids', 'signInEmails', 'displayName', 'updatedAt'])
            && request.resource.data.roles == resource.data.roles
            && request.resource.data.state == resource.data.state);
      allow delete: if false;
    }
    match /organizations/{orgId}/employeeProfiles/{userId} {
      allow read: if isStaff() || isSelf(userId);
      allow create: if isAdmin() || isManager();
      // Admins/managers may edit any field. A person may self-serve only their
      // own display preferences (preferred name, pronouns, notification prefs) —
      // never employment terms like classification, hours, or qualifications.
      allow update: if isAdmin() || isManager()
        || (isSelf(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['preferredName', 'pronouns', 'notificationPrefs', 'updatedAt']));
      allow delete: if false;
    }

    // ---- Availability & exceptions ----
    // Owners manage their own; managers/admins may edit on an employee's behalf
    // (e.g. recording a call-out). Not deletable — supersede instead.
    match /organizations/{orgId}/availabilityPatterns/{patternId} {
      allow read: if isStaff() || owns(resource.data.employeeId);
      allow create: if isStaff() || owns(request.resource.data.employeeId);
      allow update: if isStaff()
        || (owns(resource.data.employeeId)
            && request.resource.data.employeeId == resource.data.employeeId);
      allow delete: if false;
    }
    // Working-hours patterns are saved per term (Fall/Spring/…). Unlike
    // availability, an owner or manager may remove a saved schedule template;
    // the deletion is captured in the audit trail.
    match /organizations/{orgId}/workingHoursPatterns/{patternId} {
      allow read: if isStaff() || owns(resource.data.employeeId);
      allow create: if isStaff() || owns(request.resource.data.employeeId);
      allow update: if isStaff()
        || (owns(resource.data.employeeId)
            && request.resource.data.employeeId == resource.data.employeeId);
      allow delete: if isStaff() || owns(resource.data.employeeId);
    }
    match /organizations/{orgId}/leaveRecords/{leaveId} {
      allow read: if isStaff() || owns(resource.data.employeeId);
      allow create: if isStaff() || owns(request.resource.data.employeeId);
      allow update: if isStaff() || owns(resource.data.employeeId);
      allow delete: if false;
    }
    match /organizations/{orgId}/globalExceptions/{exceptionId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isManager();
    }
    match /organizations/{orgId}/managerNotes/{noteId} {
      allow read, write: if isStaff();
    }

    // ---- Daily notes (dashboard feed) ----
    // Signed-in users read published notes; managers author their own drafts;
    // only admins may flip `published` (publish/unpublish).
    match /organizations/{orgId}/dailyNotes/{noteId} {
      allow read: if isStaff() || (signedIn() && resource.data.published == true);
      allow create: if isAdmin() || (isManager() && request.resource.data.published == false);
      allow update: if isAdmin()
        || (isManager() && owns(resource.data.authorId) && unchanged('published'));
      allow delete: if isAdmin() || (isManager() && owns(resource.data.authorId));
    }

    // ---- Scheduling ----
    match /organizations/{orgId}/schedules/{scheduleId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if false;
    }
    match /organizations/{orgId}/shifts/{shiftId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if false;
    }
    match /organizations/{orgId}/coverageRequirements/{reqId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff(); // transient planning data
    }
    match /organizations/{orgId}/swapRequests/{swapId} {
      allow read: if isStaff()
        || owns(resource.data.fromEmployeeId)
        || owns(resource.data.toEmployeeId);
      allow create: if signedIn();
      allow update: if isStaff(); // approvals/decisions are manager-gated
      allow delete: if false;
    }
    match /organizations/{orgId}/complianceOverrides/{id} {
      allow read, write: if isStaff();
    }

    // ---- Operational configuration (admin- or manager-managed) ----
    match /organizations/{orgId}/positions/{id} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      // Staff may archive (via `active`) or hard-delete a position outright.
      allow delete: if isStaff();
    }
    match /organizations/{orgId}/tasks/{id} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      // Staff may archive (via `active`) or hard-delete a task outright.
      allow delete: if isStaff();
    }
    match /organizations/{orgId}/operatingHours/{id} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if false;
    }

    // ---- Structural configuration (admin-managed reference data) ----
    match /organizations/{orgId}/leaveTypes/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    match /organizations/{orgId}/locations/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    match /organizations/{orgId}/departments/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    match /organizations/{orgId}/teams/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    match /organizations/{orgId}/breakPolicies/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ---- Notifications (per-user; created by trusted server on publish) ----
    match /organizations/{orgId}/notifications/{id} {
      allow read: if isAdmin() || isSelf(resource.data.userId);
      allow create: if isStaff();
      allow update: if isSelf(resource.data.userId) && unchanged('userId'); // mark read only
      allow delete: if false;
    }

    // ---- Audit trail (append-only; written only by trusted server code) ----
    match /organizations/{orgId}/auditEvents/{id} {
      allow read: if isAdmin() || hasRole('AUDITOR');
      allow write: if false;
    }

    // ---- Maintenance tasks (admin-triggered server jobs, e.g. "import sign-ins") ----
    // An admin enqueues a request; a Cloud Function (Admin SDK, bypasses rules)
    // runs it and writes the result back. Admins read their result; clients never
    // update or delete — only the trusted trigger does.
    match /organizations/{orgId}/maintenance/{taskId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Default deny — anything not explicitly allowed above is refused.
    match /{document=**} { allow read, write: if false; }
  }
}
